{% import 'tank_macros.j2' as tank_macro %}
<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>玩家数据面板</title>
  <style>
    /* =========================
       基础重置 & 全局
    ========================== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    @font-face {
      font-family: 'SourceHanSansSC';
      src: url('{{ font_url }}') format("truetype");
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    body {
      background: #f1f3f5;
      font-family: 'SourceHanSansSC', "Microsoft YaHei", sans-serif;
      font-size: 33px;
      font-weight: 500;
      color: #1a1e22;
      padding: 20px;
      line-height: 1.4;
      text-shadow: 0 0 1px rgba(0,0,0,0.1);
    }

    .container {
      max-width: 2560px;
      margin: 0 auto;
      background: #fff;
      border-radius: 16px;
      padding: 24px;
      box-shadow:
        0 10px 40px rgba(0, 0, 0, 0.08),
        0 2px 8px rgba(0, 0, 0, 0.05);
      border: 1px solid #e9ecef;
    }

    /* =========================
       模块结构
    ========================== */
    .module {
      margin-bottom: 32px;
      border-radius: 12px;
      background: #ffffff;
      box-shadow: 0 3px 15px rgba(0,0,0,.04);
      overflow: hidden;
    }

    .module-title {
      text-align: center;
      font-size: 1.4em;
      padding: 16px;
      background: linear-gradient(180deg, #495057 0%, #343a40 100%);
      color: #ffffff;
      margin-bottom: 0;
      border-bottom: 1px solid #dee2e6;
      font-weight: bold;
      letter-spacing: 1px;
    }

    /* =========================
       表格基础（核心调整：增大行高，优化对齐）
    ========================== */
    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      margin: 0;
      padding: 0;
    }

    /* 调整表头高度：上下padding从4px→12px，更宽松 */
    table th {
      background: linear-gradient(180deg, #e9ecef 0%, #f8f9fa 100%);
      padding: 12px 4px; /* 关键：增大上下内边距，提升表头高度 */
      border: 1px solid #dee2e6;
      text-align: center;
      font-size: 1em;
      font-weight: 500;
      color: #1a1e22;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* 调整内容高度：上下padding从4px→10px，和表头匹配 */
    table td {
      padding: 10px 2px; /* 关键：增大上下内边距，提升内容行高 */
      border: 1px solid #e9ecef;
      text-align: center;
      font-size: 1em;
      font-weight: 500;
      color: #1a1e22;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    table tr:nth-child(even) {
      background: #fafbfc;
    }

    table tr:hover {
      background: #eef2f7;
    }

    /* =========================
       表格类型区分（统一字号，避免混乱）
    ========================== */
    .table-player-header th, .table-player-header td { font-size: 1.2em; }
    .table-player-core th, .table-player-core td { font-size: 1.2em; }
    .table-frequent-tank { table-layout: auto; }
    .table-frequent-tank th, .table-frequent-tank td { font-size: 1.2em; }
    .table-summary-overall th, .table-summary-overall td { font-size: 1.2em; }
    .table-summary-tank { table-layout: auto; }
    .table-summary-tank th, .table-summary-tank td { font-size: 1.2em; }

    /* =========================
       盒子模块（无多余间距）
    ========================== */
    .box-player {
      padding: 0;
      margin-bottom: 24px;
    }

    .box-frequent-tank {
      padding: 0;
    }

    /* =========================
       战绩模块（修复容器缺失，统一间距）
    ========================== */
    .summary-content {
      padding: 0 !important;
      margin: 0 !important;
      width: 100%;
    }

    .summary-time {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      padding: 16px;
      background: #f8f9fa;
      text-align: center;
      margin: 0 0 16px 0 !important;
      border: 1px solid #dee2e6;
      border-radius: 0;
      font-size: 1.05em;
      color: #495057;
      width: 100%;
    }

    .table-summary-overall {
      margin-bottom: 24px !important;
    }

    /* =========================
       高亮 & 颜色体系（优化色值，更醒目）
    ========================== */
    .highlight-win { color: #198754; }
    .highlight-loss { color: #dc3545; }
    .premium-tank { color: #fd7e14; font-weight: bold; }
    .normal-tank { color: #212529; }

    .power-red { color: #dc3545; }
    .power-green { color: #198754; }
    .power-blue { color: #0d6efd; }
    .power-purple { color: #b30aec; }
    .power-gold { color: #fd7e14; }

    .power-float-up { color: #198754; }
    .power-float-down { color: #dc3545; }
    .power-float-other{ color: #212529}

    .tank-type-spg { color: #dc3545; }
    .tank-type-medium { color: #fd7e14; }
    .tank-type-at-spg { color: #0d6efd; }
    .tank-type-heavy { color: #343a40; }
    .tank-type-light { color: #198754; }

    /* =========================
       响应式优化（适配更小屏幕）
    ========================== */
    @media (max-width: 1920px) {
      body { font-size: 28px; } /* 大屏适配，降低字号 */
    }
    @media (max-width: 1200px) {
      body { font-size: 20px; }
      .summary-time { grid-template-columns: 1fr; }
      table th { padding: 8px 4px; }
      table td { padding: 6px 2px; }
      .box-player { margin-bottom: 16px; }
      .summary-time { margin-bottom: 12px !important; }
      .table-summary-overall { margin-bottom: 16px !important; }
    }
    @media (max-width: 768px) {
      body { font-size: 16px; padding: 10px; }
      .container { padding: 12px; }
      .module-title { padding: 12px; font-size: 1.2em; }
    }
  </style>
</head>

<body>
<div class="container">

  <!-- ================= 模块一：盒子 ================= -->
  <section class="module module-box">
    <div class="module-title">盒子数据</div>

    <div class="box-player">
      <table class="table-player-header">
        <tr>
          <th>玩家</th><th>效率</th><th>更新时间</th>
        </tr>
        <tr>
          <td>{{ ctx.player_stats.name }}</td>
          <td>
              <span class="{{ tank_macro.power_class(ctx.player_stats.power) }}">
                  {{ ctx.player_stats.power }}
              </span>
              <span class="{{ tank_macro.power_float_class(ctx.player_stats.power_float) }}">
                  {{ ctx.player_stats.power_float }}
              </span>
          </td>
          <td>{{ ctx.player_stats.update_time }}</td>
        </tr>
      </table>

      <table class="table-player-core">
        <tr>
          <th>胜率</th><th>胜</th><th>负</th><th>总</th>
          <th>命中率</th><th>等级</th><th>杀伤</th>
          <th>经验</th><th>击毁</th><th>占领</th><th>防守</th><th>发现</th>
        </tr>
        <tr>
          <td>{{ ctx.player_stats.win_rate }}</td>
          <td class="highlight-win">{{ ctx.player_stats.win_count }}</td>
          <td class="highlight-loss">{{ ctx.player_stats.lose_count }}</td>
          <td>{{ ctx.player_stats.total_count }}</td>
          <td>{{ ctx.player_stats.hit_rate }}</td>
          <td>{{ ctx.player_stats.avg_tier }}</td>
          <td>{{ ctx.player_stats.avg_damage }}</td>
          <td>{{ ctx.player_stats.avg_exp }}</td>
          <td>{{ ctx.player_stats.avg_kill }}</td>
          <td>{{ ctx.player_stats.avg_occupy }}</td>
          <td>{{ ctx.player_stats.avg_defense }}</td>
          <td>{{ ctx.player_stats.avg_discovery }}</td>
        </tr>
      </table>
    </div>

    <div class="box-frequent-tank">
      <table class="table-frequent-tank">
        <tr>
          <th>常用坦克</th><th>等级</th><th>类型</th><th>胜率</th>
          <th>胜</th><th>场均效率</th><th>场均伤害</th>
          <th>场均经验</th><th>场均击毁</th><th>场均银币</th><th>命中率</th>
        </tr>
        {% for item in ctx.frequent_tank %}
        <tr>
          <td>
              <span class="{{ tank_macro.tank_premium_class(item.tank_info.premium) }}">
                  {{ item.tank_info.name }}
              </span>
          </td>
          <td>{{ item.tank_info.tier }}</td>
          <td>
          <span class="{{ tank_macro.tank_type_class(item.tank_info.type.code) }}">
              {{ item.tank_info.role.display_name }}
          </span>
          </td>
          <td>{{ item.win_rate }}</td>
          <td class="highlight-win">{{ item.win_count }}</td>
          <td>
              <span class="{{ tank_macro.power_class(item.avg_power) }}">
                  {{ item.avg_power }}
              </span>
          </td>
          <td>{{ item.avg_damage }}</td>
          <td>{{ item.avg_exp }}</td>
          <td>{{ item.avg_destroy }}</td>
          <td>{{ item.avg_credits }}</td>
          <td>{{ item.hit_rate }}</td>
        </tr>
        {% endfor %}
      </table>
    </div>
  </section>

  <!-- ================= 模块二：战绩（修复容器包裹） ================= -->
  <section class="module module-summary">
    <div class="module-title">{{ ctx.final_summary.summary_title }}</div>
    <!-- 新增summary-content容器，保证间距统一 -->
    <div class="summary-content">
        {# 只有当 query_time 或 last_battle_time 不为空时才渲染时间栏 #}
        {% if ctx.final_summary.query_time or ctx.final_summary.last_battle_time %}
        <div class="summary-time">
          {% if ctx.final_summary.query_time %}
            <div>查询时间：{{ ctx.final_summary.query_time }}</div>
          {% endif %}
          {% if ctx.final_summary.last_battle_time %}
            <div>最后战斗时间：{{ ctx.final_summary.last_battle_time }}</div>
          {% endif %}
        </div>
    {% endif %}

    {# 核心判断：如果 overall_summary 为 None，则不渲染汇总表格 #}
    {% if ctx.final_summary.overall_summary %}
      <table class="table-summary-overall">
        <tr>
          <th>出战等级</th><th>胜率</th><th>效率</th>
          <th>场次</th><th>胜</th><th>负</th><th>平</th>
          <th>场均伤害</th><th>场均协助</th><th>场均抵挡</th>
          <th>场均经验</th><th>场均银币</th><th>场均存活</th>
        </tr>
        <tr>
          <td>{{ ctx.final_summary.overall_summary.avg_tier }}</td>
          <td>{{ ctx.final_summary.overall_summary.win_rate | win_rate }}</td>
          <td>
              <span class="{{ tank_macro.power_class(ctx.final_summary.overall_summary.avg_power) }}">
                  {{ ctx.final_summary.overall_summary.avg_power }}
              </span>
          </td>
          <td>{{ ctx.final_summary.overall_summary.total_count }}</td>
          <td class="highlight-win">{{ ctx.final_summary.overall_summary.win_count }}</td>
          <td class="highlight-loss">{{ ctx.final_summary.overall_summary.lose_count }}</td>
          <td>{{ ctx.final_summary.overall_summary.draw_count }}</td>
          <td>{{ ctx.final_summary.overall_summary.avg_damage }}</td>
          <td>{{ ctx.final_summary.overall_summary.avg_assist_total }}</td>
          <td>{{ ctx.final_summary.overall_summary.avg_block }}</td>
          <td>{{ ctx.final_summary.overall_summary.avg_exp }}</td>
          <td>{{ ctx.final_summary.overall_summary.avg_credits }}</td>
          <td>{{ ctx.final_summary.overall_summary.avg_life_time | wot_time }}</td>
        </tr>
      </table>
    {% else %}
    {# 可选：在此处增加一个无数据的文字提示 #}
      <div style="padding: 20px; text-align: center; color: #999;">
        暂无该时间段内的详细对战记录
      </div>
    {% endif %}
    {# 核心判断：如果 tank_summary 为空或为 None，则不渲染坦克详情列表 #}
    {% if ctx.final_summary.tank_summary %}
      <table class="table-summary-tank">
        <tr>
          <th>序号</th><th>坦克</th><th>国家</th><th>等级</th><th>类型</th>
          <th>环</th><th>胜率</th><th>场次</th>
          <th>胜</th><th>负</th><th>平</th>
          <th>场均效率</th><th>场均伤害</th><th>场均协助</th>
          <th>场均抵挡</th><th>场均经验</th><th>场均银币</th><th>场均存活</th>
        </tr>
        {% for tank in ctx.final_summary.tank_summary %}
        <tr>
        <td>{{ loop.index }}</td>
        <td>
            <span class="{{ tank_macro.tank_premium_class(tank.tank_info.premium) }}">
                {{ tank.tank_info.name }}
            </span>
        </td>
        <td>{{ tank.tank_info.nation.display_name }}</td>
        <td>{{ tank.tank_info.tier }}</td>
        <td>
            <span class="{{ tank_macro.tank_type_class(tank.tank_info.type.code) }}">
                {{ tank.tank_info.role.display_name }}
            </span>
        </td>
        <td>{{ tank.gun_marks }}</td>
        <td>{{ tank.win_rate | win_rate }}</td>
        <td>{{ tank.total_count }}</td>
        <td class="highlight-win">{{ tank.win_count }}</td>
        <td class="highlight-loss">{{ tank.lose_count }}</td>
        <td>{{ tank.draw_count }}</td>
        <td>
            <span class="{{ tank_macro.power_class(tank.avg_power) }}">
            {{ tank.avg_power }}
            </span>
        </td>
        <td>{{ tank.avg_damage }}</td>
        <td>{{ tank.avg_assist_total }}</td>
        <td>{{ tank.avg_block }}</td>
        <td>{{ tank.avg_exp }}</td>
        <td>{{ tank.avg_credits }}</td>
        <td>{{ tank.avg_life_time | wot_time }}</td>
        </tr>
        {% endfor %}
      </table>
    {% endif %}
    </div>
  </section>

</div>
</body>
</html>